msgid "``:annotation/country``"
msgstr ""

#: locations-specific.rst:406
msgid "``ye``, ``ng``, ``mm``"
msgstr ""

#: locations-specific.rst:411
msgid "Values for this attribute are the ISO 3166-1 alpha-2 country codes, which can be found `on the ISO website <https://www.iso.org/obp/ui/#search/code/>`__."
