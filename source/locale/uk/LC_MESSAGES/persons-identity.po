msgstr ""

#: persons-identity.rst:442
msgid "``:assertion/person:account-id``"
msgstr ""

#: persons-identity.rst:447
msgid "``CapitaineIb226`` (on X)"
msgstr ""

#: persons-identity.rst:452
msgid "This attribute is used to record the account name held by the person on a specific online platform or service. Where a person has more than one account, on the same or different platforms, a new claim should be created."
msgstr ""

#: persons-identity.rst:455
msgid "person:media_description:annotation"
msgstr ""

#: persons-identity.rst:461
msgid "Short textual description of material found in a media resource that provides information about how a person looks or sounds."
msgstr ""

#: persons-identity.rst:476
msgid "``:annotation/person:media-description``"
msgstr ""

#: persons-identity.rst:481
msgid "\"Face and shoulders of Bosco Ntaganda, in military uniform with hat, tie and lapels, backed by two other men in combat fatigues armed with rifles. Taken at a news conference in January 2009.\""
msgstr ""

#: persons-identity.rst:486
msgid "This attribute is used to store a brief description of the content of external media. The description should be sufficient for the analyst to quickly appraise what they can expect to find in the media about what the person looks or sounds like. A new row is created for each distinct media item about the person."
msgstr ""

#: persons-identity.rst:489
msgid "country:annotation"
msgstr ""

#: persons-identity.rst:495
msgid "Country person is associated with for grouping claims."
msgstr ""

#: persons-identity.rst:500
msgid "Text, controlled vocabulary"
msgstr ""

#: persons-identity.rst:510
msgid "``:annotation/country``"
msgstr ""

#: persons-identity.rst:515
msgid "``mx``, ``ph``"
msgstr ""

#: persons-identity.rst:520
msgid "Values for this field are chosen from the list of ISO 3166-1 alpha-2 codes, which can be found (`on the ISO website <https://www.iso.org/obp/ui/#search>`_). This field is used to aid grouping persons into datasets related to specific countries and does not denote the citizenship or country of origin of a person. The specific country code should be chosen based on any related :ref:`posting` the :ref:`person` holds, or any other contextual information from citations about the :ref:`person`."
msgstr ""

